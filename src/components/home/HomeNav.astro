---
import { useTranslations, getLocalizedSlug } from "../../i18n/utils";
import { Icon } from "astro-icon/components";
import "./HomeNav.css";

interface Props {
    lang: "en" | "fr" | "es";
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);

const appsPath = `/${lang}/${getLocalizedSlug(lang, "apps")}/`;
const utilitiesPath = `/${lang}/${getLocalizedSlug(lang, "utilities")}/`;
---

<nav class="home-nav">
    <div class="nav-grid">
        <a href={appsPath} class="nav-card">
            <div class="card-icon">
                <Icon name="mdi:rocket-launch-outline" />
            </div>
            <div class="card-content">
                <h2>{t("menu.apps")}</h2>
                <p>{t("home.explore_apps")}</p>
            </div>
            <div class="card-arrow">
                <Icon name="mdi:chevron-right" />
            </div>
        </a>

        <a href={utilitiesPath} class="nav-card">
            <div class="card-icon">
                <Icon name="mdi:hammer-screwdriver" />
            </div>
            <div class="card-content">
                <h2>{t("menu.utilities")}</h2>
                <p>{t("home.explore_utils")}</p>
            </div>
            <div class="card-arrow">
                <Icon name="mdi:chevron-right" />
            </div>
        </a>
    </div>
</nav>
