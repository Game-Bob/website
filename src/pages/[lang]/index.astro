---
import Layout from "../../layouts/Layout.astro";
import HomeTemplate from "../../components/home/HomeTemplate.astro";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "fr");
---

<Layout title={t("home.title")} lang={lang as string} showHeader={false}>
    <HomeTemplate lang={lang as "en" | "fr"} />
</Layout>
