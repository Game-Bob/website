---
import Layout from "../../layouts/Layout.astro";
import HomeTemplate from "../../components/home/HomeTemplate.astro";
import { SUPPORTED_LANGUAGES, useTranslations, type Language } from "../../i18n/utils";

export function getStaticPaths() {
    return SUPPORTED_LANGUAGES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as Language);
---

<Layout title={t("home.title")} description={t("home.description")} lang={lang as string}>
    <HomeTemplate lang={lang as Language} />
</Layout>
