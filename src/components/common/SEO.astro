---
import { getTranslatedUrl, getExternalLanguageUrl } from "../../i18n/routerUtils";
import { SUPPORTED_LANGUAGES, externalLanguages } from "../../i18n/utils";
import OpenGraph from "./OpenGraph.astro";

interface Props {
    title: string;
    description: string;
    image?: string;
    article?: boolean;
    publishedTime?: string;
    modifiedTime?: string;
    lang?: string;
}

const {
    title,
    description,
    image = "/og-default.webp",
    article = false,
    publishedTime,
    modifiedTime,
    lang = "en",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title;
const imageURL = new URL(image, Astro.url);

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const isUtility = pathSegments.length === 5;
const manifestUrl = isUtility ? `${Astro.url.pathname}manifest.json` : "/manifest.json";

const alternateUrls: Array<{ lang: string; url: string }> = [];

for (const altLang of SUPPORTED_LANGUAGES) {
    const translatedPath = await getTranslatedUrl(Astro.url.pathname, lang, altLang);
    const altUrl = new URL(translatedPath, Astro.site);
    alternateUrls.push({ lang: altLang, url: altUrl.href });
}

for (const [extLang, extUrl] of Object.entries(externalLanguages)) {
    const externalUrl = await getExternalLanguageUrl({
        pathname: Astro.url.pathname,
        currentLang: lang,
        targetLang: extLang,
        externalDomain: extUrl
    });
    alternateUrls.push({ lang: extLang, url: externalUrl });
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/webp" href="/favicon.webp" sizes="any" />
<link rel="apple-touch-icon" href={isUtility ? image : "/apple-touch-icon-brand.webp"} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={isUtility ? title : "jjlmoya"} />
<meta name="apple-mobile-web-app-start-url" content={isUtility ? Astro.url.pathname : "/"} />
<link rel="manifest" href={manifestUrl} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#0f172a" />
<meta name="author" content="jjlmoya" />

<link rel="canonical" href={canonicalURL} />
{alternateUrls.map(({ lang: altLang, url }) => (
    <link rel="alternate" hreflang={altLang} href={url} />
))}
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<OpenGraph
    title={fullTitle}
    description={description}
    imageURL={imageURL}
    url={Astro.url}
    article={article}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
/>

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "jjlmoya",
        url: Astro.site,
        sameAs: ["https://twitter.com/jjlmoya", "https://github.com/jjlmoya"],
        jobTitle: "Creative Developer",
        worksFor: {
            "@type": "Organization",
            name: "GameBob Studio",
        },
    })}
/>
