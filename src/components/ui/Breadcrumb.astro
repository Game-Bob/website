---
import { Icon } from "astro-icon/components";
import { getUtilitiesHubUrl } from "../../i18n/routerUtils";
import { useTranslations } from "../../i18n/utils";
import { slugMapping } from "../../i18n/utils";
import type { Language } from "../../i18n/utils";
import "./breadcrumb.css";

interface Props {
    category?: string;
    categorySlug?: string;
    title?: string;
    lang?: string;
}

const { category, categorySlug, title, lang = "en" } = Astro.props;
const t = useTranslations(lang as Language);
const hubUrl = getUtilitiesHubUrl(lang);
const categoryUrl = categorySlug ? `/${lang}/${slugMapping.utilities[lang as Language]}/${slugMapping.categories[lang as Language]}/${categorySlug}/` : "";
---

<nav class="breadcrumb" aria-label="Breadcrumb">
    <ol class="breadcrumb-list">
        <li class="breadcrumb-item">
            <a href={hubUrl} class="breadcrumb-link">
                {t("ui.all_tools")}
            </a>
        </li>
        {category && (
            <>
                <li class="breadcrumb-separator">
                    <Icon name="mdi:chevron-right" class="separator-icon" />
                </li>
                <li class="breadcrumb-item">
                    <a href={categoryUrl} class="breadcrumb-link">
                        {category}
                    </a>
                </li>
            </>
        )}
        {title && (
            <>
                <li class="breadcrumb-separator">
                    <Icon name="mdi:chevron-right" class="separator-icon" />
                </li>
                <li class="breadcrumb-item breadcrumb-current">
                    <span>{title}</span>
                </li>
            </>
        )}
    </ol>
</nav>
