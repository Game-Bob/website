---
import Layout from "../../../../layouts/Layout.astro";
import CardUtility from "../../../../components/utilities/CardUtility.astro";
import { SUPPORTED_LANGUAGES, slugMapping, type Language } from "../../../../i18n/utils";
import { CATEGORIES } from "../../../../data/utilities/registry";
import { buildSection } from "../../../../data/utilities/builder";

export async function getStaticPaths() {
    const paths = [];

    for (const lang of SUPPORTED_LANGUAGES) {
        const utilitiesParam = slugMapping.utilities[lang];
        const categoriesParam = slugMapping.categories[lang];

        for (const catDef of CATEGORIES) {
            const section = await buildSection(lang, catDef);
            paths.push({
                params: { lang, utilities: utilitiesParam, categories: categoriesParam, slug: section.slug },
                props: { lang, section, categoryEntry: catDef.entry, CategorySEOComponent: catDef.SEOComponent, imageSlug: slugMapping[catDef.key].en, categoryKey: catDef.key },
            });
        }
    }
    return paths;
}

const { lang: langProp, section, categoryEntry, CategorySEOComponent, imageSlug, categoryKey } = Astro.props;
const lang = langProp as Language;
const content = await categoryEntry.i18n[lang]!();
const finalImageSlug = categoryKey === "converters" ? "universal-image-converter" : imageSlug;
const image = `/images/utilities/${finalImageSlug}.webp`;
const description = content.description;
---

<Layout title={content.title} description={description} image={image} lang={lang}>
    <section class="category-page">
        <header class="category-header">
            <h1 class="category-title">{section.title}</h1>
            <p class="category-description">{section.description}</p>
        </header>

        <div class="utilities-grid">
            {section.utilities.map((utility) => (
                <CardUtility {...utility} lang={lang} />
            ))}
        </div>

        <CategorySEOComponent locale={lang} />
    </section>
</Layout>

<style>
    .category-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--space-xl) var(--space-md);
    }

    .category-header {
        margin-bottom: var(--space-xl);
        text-align: center;
    }

    .category-title {
        font-size: clamp(3.5rem, 9vw, 7rem);
        font-weight: 900;
        text-transform: lowercase;
        letter-spacing: -0.06em;
        margin: 0;
        color: var(--text-main);
    }

    .category-description {
        color: var(--text-muted);
        font-size: 1.25rem;
        margin-top: 1rem;
    }

    .utilities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: var(--space-lg);
    }

    @media (width <= 768px) {
        .category-page {
            padding: var(--space-lg) var(--space-sm);
        }
    }
</style>
