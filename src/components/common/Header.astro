---
import { languages, externalLanguages, getLocalizedSlug, useTranslations, SUPPORTED_LANGUAGES, type Language } from "../../i18n/utils";
import { getTranslatedUrl, getExternalLanguageUrl } from "../../i18n/routerUtils";
import MobileMenu from "./MobileMenu.astro";
import LanguageSheet from "./LanguageSheet.astro";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageTrigger from "./LanguageTrigger.astro";
import "./Header.css";

const pathname = new URL(Astro.request.url).pathname;
const langFromPath = pathname.split('/')[1] || "en";
const lang = SUPPORTED_LANGUAGES.includes(langFromPath as Language) ? (langFromPath as Language) : "en" as Language;

interface Props { className?: string; }
const { className = "" } = Astro.props;

const t = useTranslations(lang);
const aSlug = getLocalizedSlug(lang, "apps");
const uSlug = getLocalizedSlug(lang, "utilities");
const aPath = `/${lang}/${aSlug}/`;
const uPath = `/${lang}/${uSlug}/`;

const transUrls = await Promise.all(
    Object.keys({ ...languages, ...externalLanguages }).map(async (l) => {
        if (externalLanguages[l]) {
            return {
                lang: l,
                url: await getExternalLanguageUrl({
                    pathname,
                    currentLang: lang,
                    targetLang: l,
                    externalDomain: externalLanguages[l]
                })
            };
        }
        return { lang: l, url: await getTranslatedUrl(pathname, lang, l) };
    })
);
---

<nav class={`main-nav ${className}`} id="main-nav">
    <div class="nav-container">
        <a href={`/${lang}/`} class="nav-logo">Game<span>Bob</span></a>
        <div class="nav-links">
            <a href={aPath} class={`nav-link ${pathname.includes(aSlug) ? "nav-active" : ""}`}>{t("menu.apps")}</a>
            <a href={uPath} class={`nav-link ${pathname.includes(uSlug) ? "nav-active" : ""}`}>{t("menu.utilities")}</a>
            <div class="nav-separator"></div>
            <div class="nav-actions">
                <ThemeToggle />
                <div class="nav-separator sm-only"></div>
                <div class="lang-switcher">
                    {transUrls.map(({ lang: l, url }) => (
                        <a href={url} class={`lang-link ${l === lang ? 'active' : ''}`}>{l}</a>
                    ))}
                </div>
            </div>
        </div>
        <button id="menu-toggle" class="menu-toggle" aria-label="Menu">
            <span class="toggle-line line-1"></span><span class="toggle-line line-2"></span>
        </button>
    </div>
</nav>

<MobileMenu aPath={aPath} uPath={uPath} aSlug={aSlug} uSlug={uSlug} aLabel={t("menu.apps")} uLabel={t("menu.utilities")} pathname={pathname}>
    <ThemeToggle slot="theme-toggle" mobile />
    <LanguageTrigger slot="language-trigger" />
</MobileMenu>

<LanguageSheet transUrls={transUrls} currentLang={lang} title={t("ui.select_language")} />

<script>
    function setupHeader() {
        document.getElementById("menu-toggle")?.addEventListener("click", (e) => {
            e.stopPropagation();
            window.toggleMobileMenu?.();
        });
    }

    document.addEventListener("astro:page-load", setupHeader);
    setupHeader();
</script>
