---
import { useTranslations, type Language } from "../../i18n/utils";
import CardUtility from "./CardUtility.astro";
import "./RelatedUtilities.css";
import { getSections } from "../../data/utilities/index";

interface Props {
    category: string;
    currentPath: string;
    lang?: string;
}

const { currentPath, lang = "en" } = Astro.props;
const t = useTranslations(lang as Language);

const pathSegments = currentPath.split('/').filter(Boolean);
const categorySlug = pathSegments[3] ?? "";

const sections = await getSections(lang as Language);
const section = sections.find(s => s.slug === categorySlug);
const relatedUtilities = section?.utilities.filter((u: { href: string }) => u.href !== currentPath) ?? [];
---

{
    relatedUtilities.length > 0 && (
        <section class="related-section">
            <h2 class="related-title">
                {t("ui.related_utils_title")}{" "}
                <span class="category-highlight">{section?.title}</span>
            </h2>
            <div class="related-grid">
                {relatedUtilities.map((u) => (
                    <CardUtility {...u} lang={lang} />
                ))}
            </div>
        </section>
    )
}
