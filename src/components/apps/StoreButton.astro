---
import { Icon } from 'astro-icon/components';
import './StoreButton.css';

interface Props {
    href: string;
    platform: 'google-play' | 'apple';
    text: string;
    variant?: 'solid' | 'outline';
}

const { href, platform, text, variant = 'solid' } = Astro.props;

const iconName = platform === 'google-play' ? 'mdi:google-play' : 'mdi:apple';
---

<a href={href} target="_blank" rel="noopener noreferrer" class={`store-button store-button--${variant} store-button--${platform}`}>
    <Icon name={iconName} class="store-button-icon" />
    <span class="store-button-text">{text}</span>
</a>
