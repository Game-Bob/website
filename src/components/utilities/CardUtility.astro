---
import { Icon } from "astro-icon/components";
import { useTranslations } from "../../i18n/utils";
import "./CardUtility.css";

interface Props {
    href: string;
    title: string;
    description: string;
    seoDescription?: string;
    iconBg: string;
    iconFg: string;
    color: string;
    lang?: string;
}

const { href, title, description, seoDescription, iconBg, iconFg, color, lang = "en" } = Astro.props;
const t = useTranslations(lang as any);
---

<a
    href={href}
    class="card-utility"
    style={`--theme-color: ${color}`}
    data-utility-card
    data-title={title}
    data-description={description}
>
    <div class="card-content">
        <div class="icon-box">
            <Icon name={iconFg} class="icon-svg" />
        </div>

        <h2 class="card-title">
            {title}
        </h2>
        <p class="card-description">
            {description}
        </p>
        {seoDescription && <p class="card-seo-description">{seoDescription}</p>}

        <div class="card-footer">
            <span>{t("ui.use_tool")}</span>
            <Icon
                name="mdi:arrow-right"
                class="arrow-icon"
            />
        </div>
    </div>
</a>
