---
import { useTranslations, getLocalizedSlug } from "../../i18n/utils";
import "./Header.css";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as "en" | "fr");
const appsPath = `/${lang}/${getLocalizedSlug(lang, "apps")}/`;
const utilitiesPath = `/${lang}/${getLocalizedSlug(lang, "utilities")}/`;
---

<header class="main-header">
    <div class="header-container">
        <a href={`/${lang}/`} class="logo-link">
            <img src="/images/gamebob/index.webp" alt="GameBob Logo" class="header-logo" />
        </a>

        <button class="mobile-toggle" aria-label="Menu" id="menuToggle">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>

        <div class="header-backdrop" id="headerBackdrop"></div>

        <nav class="header-nav" id="headerNav">
            <ul class="nav-list">
                <li><a href={appsPath}>{t("menu.apps")}</a></li>
                <li><a href={utilitiesPath}>{t("menu.utilities")}</a></li>
            </ul>
        </nav>
    </div>
</header>

<script>
    const toggle = document.getElementById("menuToggle");
    const nav = document.getElementById("headerNav");
    const backdrop = document.getElementById("headerBackdrop");
    const doc = document.documentElement;

    const toggleMenu = () => {
        const isActive = nav?.classList.toggle("is-active");
        toggle?.classList.toggle("is-active");
        backdrop?.classList.toggle("is-active");
        doc.classList.toggle("is-locked", isActive);
    };

    toggle?.addEventListener("click", toggleMenu);
    backdrop?.addEventListener("click", toggleMenu);
</script>
