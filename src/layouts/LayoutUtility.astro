---
import Layout from "./Layout.astro";
import BackToUtilities from "../components/ui/BackToUtilities.astro";
import RelatedUtilities from "../components/utilities/RelatedUtilities.astro";
import AppLinksBanner from "../components/utilities/AppLinksBanner.astro";
import UtilityStructuredData from "../components/utilities/UtilityStructuredData.astro";
import FAQSection from "../components/utilities/FAQSection.astro";
import WidgetCreator from "../components/utilities/WidgetCreator.astro";
import WidgetMessenger from "../components/utilities/WidgetMessenger.astro";
import "./LayoutUtility.css";

interface AppLinks { android?: string; ios?: string; }
interface FAQItem { question: string; answer: string; }
interface HowToStep { name: string; text: string; url?: string; image?: string; }

interface Props {
    title: string; description: string; image?: string; category?: string;
    appLinks?: AppLinks; appSlug?: string; faqItems?: FAQItem[];
    howToSteps?: HowToStep[]; hideWidget?: boolean; lang?: string;
}

const {
    title, description, image, category: propCategory,
    appLinks, appSlug, faqItems, howToSteps, 
    hideWidget = false, lang = "en"
} = Astro.props;

const currentPath = Astro.url.pathname;
const isWidget = Astro.url.searchParams.get("widget") === "true";
---

<Layout title={title} description={description} image={image} fullWidth={true}>
    <UtilityStructuredData
        title={title} description={description} url={currentPath}
        category={propCategory} faqItems={faqItems} howToSteps={howToSteps}
        slot="head"
    />
    <div class="utility-layout-wrapper">
        <div class="utility-bg-gradient"></div>
        { !isWidget && <div class="sticky-banner">
            <AppLinksBanner appSlug={appSlug} android={appLinks?.android} ios={appLinks?.ios} lang={lang} />
        </div>}

        <div class="utility-main-container">
            <div class="utility-header-area">
                <BackToUtilities lang={lang} />
                <slot name="header">
                    <h1>{title}</h1>
                    <p>{description}</p>
                </slot>
            </div>

            <div class="utility-tool-container"><slot /></div>
            {!hideWidget && <WidgetCreator title={title} url={currentPath} lang={lang} />}
            
            {faqItems && faqItems.length > 0 && <div class="no-widget-hidden">
                <FAQSection items={faqItems} lang={lang} />
            </div>}

            <div class="seo-content no-widget-hidden"><slot name="seo" /></div>
            <div class="bibliography-wrapper no-widget-hidden"><slot name="bibliography" /></div>
            <div class="no-widget-hidden">
                <RelatedUtilities category={propCategory ?? ""} currentPath={currentPath} lang={lang} />
            </div>
        </div>
    </div>

    <WidgetMessenger hasBanner={!isWidget} />
</Layout>
