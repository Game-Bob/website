---
import { SUPPORTED_LANGUAGES, slugMapping, type Language } from "../../../../../i18n/utils";
import LibraryUtilityLayout from "../../../../../components/utilities/LibraryUtilityLayout.astro";
import { CATEGORIES } from "../../../../../data/utilities/registry";
import { loadCategoryComponents } from "../../../../../data/utilities/loadCategory";
import { buildSection } from "../../../../../data/utilities/builder";

interface Props {
    lang: Language;
    toolId: string;
    catKey: string;
    section: any;
}

export async function getStaticPaths() {
    const paths = [];

    for (const lang of SUPPORTED_LANGUAGES) {
        const uParam = slugMapping.utilities[lang];
        const cParam = slugMapping.categories[lang];

        for (const catDef of CATEGORIES) {
            const section = await buildSection(lang, catDef);

            for (const { toolEntry } of catDef.toolsWithColors) {
                const toolLocale = await toolEntry.i18n[lang]!();
                paths.push({
                    params: { lang, utilities: uParam, categories: cParam, categorySlug: section.slug, toolSlug: toolLocale.slug },
                    props: { lang, section, toolId: toolEntry.id, catKey: catDef.key },
                });
            }
        }
    }
    return paths;
}

const { lang, toolId, catKey, section } = Astro.props;
const { AllTools } = await loadCategoryComponents(catKey);
const tool = AllTools.find((t: any) => t.entry.id === toolId)!;
---

<LibraryUtilityLayout
    lang={lang}
    tool={tool}
    category={section.title}
    categoryKey={catKey}
/>
