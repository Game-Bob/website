---
import Layout from "../../../layouts/Layout.astro";
import { SUPPORTED_LANGUAGES, useTranslations, slugMapping } from "../../../i18n/utils";
import { getSections } from "../../../data/utilities/index.ts";
import UtilityExplorer from "../../../components/utilities/explorer/UtilityExplorer.astro";
import SearchInput from "../../../components/utilities/SearchInput.astro";
import "./index.css";

export async function getStaticPaths() {
    return SUPPORTED_LANGUAGES.map((lang) => ({
        params: { lang, utilities: slugMapping.utilities[lang] },
        props: { lang },
    }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const sections = await getSections(lang);
---

<Layout title={t("ui.hub_title")} lang={lang} noPaddingTop>
    <section class="utility-hub">
        <div class="hub-top">
            <header class="hub-header">
                <div class="hub-header-content">
                    <h1 class="hub-title">{t("ui.hub_title")}</h1>
                    <h2 class="hub-description">{t("ui.hub_desc")}</h2>
                </div>
            </header>
            <SearchInput lang={lang} />
        </div>

        <UtilityExplorer sections={sections} lang={lang} />
    </section>
</Layout>

<script>
    function setupSearch() {
        const searchInput = document.getElementById('utility-search') as HTMLInputElement;
        const sections = document.querySelectorAll('.category-section') as NodeListOf<HTMLElement>;
        const noResults = document.getElementById('no-results') as HTMLElement;

        if (!searchInput) return;

        searchInput.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
            let totalVisible = 0;

            sections.forEach(section => {
                const categoryTitle = section.dataset.categoryTitle || '';
                const categoryItems = section.querySelectorAll('.utility-item-compact') as NodeListOf<HTMLElement>;
                let visibleInSection = 0;

                categoryItems.forEach(item => {
                    const title = item.dataset.searchTitle || '';
                    const matchesCategory = categoryTitle.includes(query);
                    const matchesItem = title.includes(query);

                    if (matchesCategory || matchesItem) {
                        item.style.display = 'flex';
                        visibleInSection++;
                        totalVisible++;
                    } else {
                        item.style.display = 'none';
                    }
                });

                if (visibleInSection > 0) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });

            if (totalVisible === 0 && query !== '') {
                noResults.hidden = false;
            } else {
                noResults.hidden = true;
            }
        });
    }

    setupSearch();
    document.addEventListener('astro:after-swap', setupSearch);
</script>
