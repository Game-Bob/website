---
import Layout from "../../../layouts/Layout.astro";
import { SUPPORTED_LANGUAGES, slugMapping } from "../../../i18n/utils";
import { useAppsTranslations } from "../../../i18n/appsTranslations";
import { ALL_APP_DEFINITIONS } from "@jjlmoya/apps";
import type { KnownLocale } from "@jjlmoya/apps";
import type { Language } from "../../../i18n/utils";
import AppCard from "../../../components/apps/AppCard.astro";
import "./index.css";

export async function getStaticPaths() {
    return SUPPORTED_LANGUAGES.map((lang) => ({
        params: { lang, apps: slugMapping.apps[lang] },
        props: { lang },
    }));
}

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const t = useAppsTranslations(lang);

const appCards = await Promise.all(
    ALL_APP_DEFINITIONS.map(async ({ entry }) => {
        const loader = entry.i18n[lang as KnownLocale] ?? entry.i18n.en;
        const card = await loader!();
        return { entry, card };
    })
);
---

<Layout title={t.hub_title} description={t.hub_desc} lang={lang} noPaddingTop>
    <section class="apps-hub">
        <header class="apps-hub-header">
            <div class="apps-hub-header-content">
                <h1 class="apps-hub-title">{t.hub_title}</h1>
                <p class="apps-hub-desc">{t.hub_desc}</p>
            </div>
        </header>

        <div class="apps-grid">
            {appCards.map(({ entry, card }) => (
                <AppCard
                    lang={lang}
                    entry={entry}
                    card={card}
                    landingHref={`/${lang}/${slugMapping.apps[lang]}/${card.slug}/`}
                    gameBadge={t.game_badge}
                    appBadge={t.app_badge}
                    getOnPlay={t.get_on_play}
                    getOnStore={t.get_on_store}
                />
            ))}
        </div>
    </section>
</Layout>
