---
import type { UtilityItem } from "../../../data/utilities/types";
import UtilityItemCompact from "./UtilityItemCompact.astro";
import { useTranslations, slugMapping, type Language } from "../../../i18n/utils";

interface Props {
    title: string;
    icon: string;
    utilities: UtilityItem[];
    slug: string;
    lang?: Language;
}

const { title, utilities, slug, lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const categoryUrl = `/${lang}/${slugMapping.utilities[lang]}/${slugMapping.categories[lang]}/${slug}/`;
---

<section class="category-section" data-category-title={title.toLowerCase()}>
    <a href={categoryUrl} class="section-header-link">
        <header class="section-header">
            <h2 class="category-title">{title}</h2>
            <span class="count-badge">{utilities.length} {utilities.length === 1 ? t('ui.tool_singular') : t('ui.tool_plural')}</span>
        </header>
    </a>

    <div class="items-grid">
        {utilities.map(item => (
            <UtilityItemCompact 
                {...item} 
                category={title}
            />
        ))}
    </div>
</section>

<style>
    .category-section {
        margin-bottom: var(--space-2xl);
        transition: opacity 0.3s ease;
    }

    .category-section[hidden] {
        display: none;
    }

    .section-header {
        display: flex;
        align-items: baseline;
        gap: var(--space-md);
        margin-bottom: var(--space-md);
    }

    .section-header-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        gap: var(--space-md);
        align-items: baseline;
        transition: opacity 0.2s;
    }

    .section-header-link:hover {
        opacity: 0.7;
    }

    .category-title {
        font-size: 1.15rem;
        font-weight: var(--font-weight-bold);
        color: var(--text-main);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0;
    }

    .count-badge {
        font-size: 0.6rem;
        background: var(--color-primary);
        color: var(--text-inverse);
        padding: var(--space-xs) var(--space-sm);
        border-radius: var(--radius-full);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        opacity: 100%;
    }

    .items-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
    }

    @media (width <= 768px) {
        .items-grid {
            grid-template-columns: 1fr;
            gap: var(--space-sm);
        }

        .category-title {
            font-size: 1rem;
        }
    }
</style>
