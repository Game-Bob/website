---
import "./MobileMenu.css";

interface Props {
    aPath: string;
    uPath: string;
}

const { aPath, uPath } = Astro.props;
---

<div id="mobile-menu-overlay" class="mobile-menu-overlay">
    <div class="mobile-menu-backdrop"></div>
    <div class="mobile-menu-panel">
        <button id="menu-close" class="menu-close" aria-label="Close menu">×</button>
        <nav class="mobile-nav">
            <a href={aPath} class="menu-link"><span class="link-number">01</span><span class="link-text">Apps</span></a>
            <a href={uPath} class="menu-link"><span class="link-number">02</span><span class="link-text">Utilities</span></a>
        </nav>
        <div class="mobile-menu-footer">
            <div class="mobile-footer-actions">
                <slot name="theme-toggle" />
                <slot name="language-trigger" />
            </div>
        </div>
    </div>
</div>

<script>
    function closeMenu() {
        const overlay = document.getElementById("mobile-menu-overlay");
        overlay?.classList.remove("active");
        document.body.classList.remove("menu-open");
        document.documentElement.classList.remove("is-locked");
    }

    function setupMobileMenu() {
        const overlay = document.getElementById("mobile-menu-overlay");
        const backdrop = document.querySelector(".mobile-menu-backdrop");
        const closeBtn = document.getElementById("menu-close");
        const links = document.querySelectorAll(".menu-link");

        closeBtn?.addEventListener("click", closeMenu);
        backdrop?.addEventListener("click", closeMenu);
        links.forEach(l => l.addEventListener("click", closeMenu));

        window.toggleMobileMenu = function() {
            overlay?.classList.toggle("active");
            document.body.classList.toggle("menu-open");
            const isOpen = overlay?.classList.contains("active");
            document.documentElement.classList.toggle("is-locked", isOpen);
        };
    }

    document.addEventListener("astro:page-load", setupMobileMenu);
    setupMobileMenu();
</script>
