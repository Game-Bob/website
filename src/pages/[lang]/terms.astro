---
import Layout from "../../layouts/Layout.astro";
import TermsOfService from "../../components/legal/TermsOfService.astro";
import { useTranslations, SUPPORTED_LANGUAGES } from "../../i18n/utils";

export function getStaticPaths() {
    return SUPPORTED_LANGUAGES.map((lang) => ({
        params: { lang },
    }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const legalContent = t("legal.terms");
---

<Layout 
    title={`${legalContent.title} | GameBob`} 
    description={legalContent.subtitle} 
    lang={lang}
>
    <main class="page-container">
        <TermsOfService content={legalContent} />
    </main>
</Layout>

<style>
    .page-container {
        min-height: 100vh;
    }
</style>
