---
import pkg from "../../../package.json";
interface HowToStep { name: string; text: string; url?: string; image?: string; }
interface Props {
    title: string; description: string; url: string; category?: string; lang?: string;
    faqItems?: Array<{ question: string; answer: string; }>; howToSteps?: HowToStep[];
}
const { title, description, url, category, faqItems, howToSteps, lang = "en" } = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://www.gamebob.dev";
const fullUrl = `${siteOrigin}${url}`;

const bcp47Map: Record<string, string> = {
    en: "en-US", fr: "fr-FR", de: "de-DE", it: "it-IT", pt: "pt-PT",
    nl: "nl-NL", sv: "sv-SE", pl: "pl-PL", id: "id-ID", tr: "tr-TR",
    ru: "ru-RU", ja: "ja-JP", ko: "ko-KR", zh: "zh-CN",
};
const inLanguage = bcp47Map[lang] ?? "en-US";

const author = { "@type": "Person", name: "jjlmoya", url: siteOrigin, sameAs: ["https://github.com/jjlmoya", "https://www.linkedin.com/in/jjlmoya/"] };
const org = { "@context": "https://schema.org", "@type": "Organization", name: "GameBob", url: siteOrigin, logo: `${siteOrigin}/images/logo.webp`, founder: author };

const getCategoryUrl = () => {
    if (!category || !url) return "";
    const urlParts = url.split('/').filter(Boolean);
    const categoryIndex = urlParts.indexOf('categories');
    if (categoryIndex === -1) return "";
    const categorySlug = urlParts[categoryIndex + 1];
    return `/${lang}/utilities/categories/${categorySlug}/`;
};

const categoryUrl = getCategoryUrl();
const breadcrumb = {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "GameBob", item: `${siteOrigin}/${lang}/` },
        ...(category && categoryUrl ? [{ "@type": "ListItem", position: 2, name: category, item: `${siteOrigin}${categoryUrl}` }] : []),
        ...(category && categoryUrl ? [{ "@type": "ListItem", position: 3, name: title, item: fullUrl }] : [{ "@type": "ListItem", position: 2, name: title, item: fullUrl }])
    ]
};
const webApp = {
    "@context": "https://schema.org", "@type": "WebApplication", name: title, description, url: fullUrl,
    applicationCategory: "UtilityApplication", operatingSystem: "Any", softwareVersion: pkg.version,
    author, creator: author, publisher: org, inLanguage,
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, browserRequirements: "Requires JavaScript. Requires HTML5.",
};
const howTo = {
    "@context": "https://schema.org", "@type": "HowTo", name: title, description, inLanguage, url: fullUrl, author, publisher: org,
    ...(howToSteps && { step: howToSteps.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.name, text: s.text, ...(s.url && { url: s.url }), ...(s.image && { image: s.image }) })) })
};
const faq = faqItems ? {
    "@context": "https://schema.org", "@type": "FAQPage",
    mainEntity: faqItems.map(it => ({ "@type": "Question", name: it.question, acceptedAnswer: { "@type": "Answer", text: it.answer } }))
} : null;
const isCalc = ["calculadora", "simulador", "marcador", "generador", "calculator", "converter", "generator", "rechner", "kalkulator"].some(k => title.toLowerCase().includes(k));
const schemas = [breadcrumb, isCalc ? webApp : howTo, ...(faq ? [faq] : [])];
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)} />
